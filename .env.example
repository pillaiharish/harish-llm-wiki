# =============================================================================
# Harish LLM Wiki - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# -----------------------------------------------------------------------------
# Data Directory (optional)
# Defaults to ~/llm-wiki-data if not set
# -----------------------------------------------------------------------------
LLM_WIKI_DATA_DIR=~/llm-wiki-data

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Options: ollama_cloud (default), openai_compatible, ollama_local
LLM_PROVIDER=ollama_cloud

# -----------------------------------------------------------------------------
# Ollama Cloud (DEFAULT PROVIDER)
# Get your API key from: https://ollama.com/settings/api
# OLLAMA_API_KEY is preferred. OLLAMA_CLOUD_API_KEY remains supported as an alias.
# -----------------------------------------------------------------------------
OLLAMA_API_KEY=
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/api
OLLAMA_CLOUD_MODEL=

# -----------------------------------------------------------------------------
# Optional: Local Ollama Fallback
# Only use if LLM_PROVIDER=ollama_local
# Requires: ollama serve && ollama pull <model>
# -----------------------------------------------------------------------------
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_LOCAL_MODEL=qwen2.5:7b

# -----------------------------------------------------------------------------
# Optional: OpenAI-Compatible Providers
# Supports: GLM Cloud, Kimi, Minimax, OpenRouter, etc.
# -----------------------------------------------------------------------------
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
